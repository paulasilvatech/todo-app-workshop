# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# PostgreSQL connection string (automatically set to docker service in docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/todoapp

# ─────────────────────────────────────────────
# GitHub OAuth App
# Create one at: https://github.com/settings/developers → "New OAuth App"
# Homepage URL:         http://localhost:5173
# Authorization callback URL: http://localhost:3001/auth/callback
# ─────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ─────────────────────────────────────────────
# GitHub Webhook
# Generate with: openssl rand -hex 32
# Configure at: Your Repo → Settings → Webhooks
# Payload URL: http://<your-ngrok-url>/github/webhook
# Content type: application/json
# Events: Issues
# ─────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ─────────────────────────────────────────────
# Encryption — for storing GitHub tokens at rest (AES-256-GCM)
# Generate with: openssl rand -hex 32   (must be exactly 64 hex chars = 32 bytes)
# ─────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=your_64_hex_char_encryption_key_here

# ─────────────────────────────────────────────
# Session — signs the session cookie
# Generate with: openssl rand -base64 32
# ─────────────────────────────────────────────
SESSION_SECRET=your_session_secret_min_32_chars_here

# ─────────────────────────────────────────────
# App URLs
# ─────────────────────────────────────────────
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
